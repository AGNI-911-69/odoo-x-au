<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Dashboard client action ───────────────────────────────────────── -->
    <record id="action_hrms_dashboard" model="ir.actions.client">
        <field name="name">Dashboard</field>
        <field name="tag">hrms_dashboard</field>
    </record>

    <!-- ── Fallback list-based dashboard for HR (shows all pending leaves) ── -->
    <record id="action_hrms_dashboard_pending" model="ir.actions.act_window">
        <field name="name">Dashboard Overview</field>
        <field name="res_model">hrms.leave</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'pending')]</field>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

</odoo>
