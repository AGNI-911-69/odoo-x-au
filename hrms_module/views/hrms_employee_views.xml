<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Kanban View ─────────────────────────────────────────────────────── -->
    <record id="view_hrms_employee_kanban" model="ir.ui.view">
        <field name="name">hrms.employee.kanban</field>
        <field name="model">hrms.employee</field>
        <field name="arch" type="xml">
            <kanban class="hrms_employee_kanban" default_group_by="" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="employee_code"/>
                <field name="job_title"/>
                <field name="department"/>
                <field name="date_joined"/>
                <field name="status"/>
                <field name="profile_image"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card hrms_emp_card">
                            <div class="hrms_emp_card_header">
                                <div class="hrms_emp_avatar">
                                    <img t-att-src="kanban_image('hrms.employee', 'profile_image', record.id.raw_value)"
                                         class="hrms_emp_img" alt="Avatar"/>
                                </div>
                                <div class="hrms_emp_status_dot">
                                    <span t-att-class="'hrms_status_dot hrms_status_' + record.status.raw_value"
                                          t-att-title="record.status.value"/>
                                    <span class="hrms_status_label" t-esc="record.status.value"/>
                                </div>
                            </div>
                            <div class="hrms_emp_body">
                                <div class="hrms_emp_name" t-esc="record.name.value"/>
                                <div class="hrms_emp_job" t-esc="record.job_title.value"/>
                                <div class="hrms_emp_dept" t-esc="record.department.value"/>
                            </div>
                            <div class="hrms_emp_footer">
                                <div>
                                    <span class="hrms_label">Employee ID</span>
                                    <span class="hrms_value" t-esc="record.employee_code.value"/>
                                </div>
                                <div>
                                    <span class="hrms_label">Joined</span>
                                    <span class="hrms_value" t-esc="record.date_joined.value"/>
                                </div>
                            </div>
                            <div class="hrms_emp_actions">
                                <a type="open" class="btn btn-sm hrms_btn_primary">View Profile</a>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── List View ──────────────────────────────────────────────────────── -->
    <record id="view_hrms_employee_list" model="ir.ui.view">
        <field name="name">hrms.employee.list</field>
        <field name="model">hrms.employee</field>
        <field name="arch" type="xml">
            <list string="Employees" decoration-muted="status == 'absent'"
                  decoration-success="status == 'present'"
                  decoration-warning="status == 'half_day'"
                  decoration-info="status == 'on_leave'">
                <field name="profile_image" widget="image" options="{'size': [40, 40]}"/>
                <field name="employee_code"/>
                <field name="name"/>
                <field name="job_title"/>
                <field name="department"/>
                <field name="role"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="date_joined"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'present'"
                       decoration-warning="status == 'half_day'"
                       decoration-danger="status == 'absent'"
                       decoration-info="status == 'on_leave'"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ── Form View ──────────────────────────────────────────────────────── -->
    <record id="view_hrms_employee_form" model="ir.ui.view">
        <field name="name">hrms.employee.form</field>
        <field name="model">hrms.employee</field>
        <field name="arch" type="xml">
            <form string="Employee Profile" class="hrms_employee_form">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="present,absent,half_day,on_leave"/>
                </header>
                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_attendance" type="object"
                                class="oe_stat_button" icon="fa-calendar-check-o">
                            <field name="attendance_count" widget="statinfo" string="Attendance"/>
                        </button>
                        <button name="action_view_leaves" type="object"
                                class="oe_stat_button" icon="fa-plane">
                            <field name="leave_count" widget="statinfo" string="Leaves"/>
                        </button>
                        <button name="action_view_leaves" type="object"
                                class="oe_stat_button" icon="fa-clock-o"
                                attrs="{'invisible': [('pending_leave_count', '=', 0)]}">
                            <field name="pending_leave_count" widget="statinfo" string="Pending"/>
                        </button>
                    </div>
                    <!-- Avatar -->
                    <field name="profile_image" widget="image"
                           class="oe_avatar" options="{'size': [128, 128]}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Employee Full Name"/>
                        </h1>
                        <h3>
                            <field name="job_title" placeholder="Job Title"/>
                        </h3>
                        <div>
                            <field name="employee_code" readonly="1"/>
                        </div>
                    </div>

                    <notebook>
                        <!-- Personal Info -->
                        <page string="Personal Information" name="personal">
                            <group>
                                <group string="Personal Details">
                                    <field name="email"/>
                                    <field name="phone"/>
                                    <field name="date_of_birth"/>
                                    <field name="gender"/>
                                    <field name="address" widget="text"/>
                                </group>
                                <group string="Employment Details">
                                    <field name="department"/>
                                    <field name="role"/>
                                    <field name="employment_type"/>
                                    <field name="date_joined"/>
                                    <field name="basic_salary"
                                           groups="hrms_module.group_hrms_hr_officer"/>
                                    <field name="user_id"
                                           groups="hrms_module.group_hrms_hr_officer"/>
                                </group>
                            </group>
                        </page>

                        <!-- Documents -->
                        <page string="Documents" name="documents">
                            <field name="document_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="document_type"/>
                                    <field name="file" filename="filename" widget="binary"/>
                                    <field name="filename" invisible="1"/>
                                    <field name="date_uploaded"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>

                        <!-- Activity / Chatter -->
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Search View ────────────────────────────────────────────────────── -->
    <record id="view_hrms_employee_search" model="ir.ui.view">
        <field name="name">hrms.employee.search</field>
        <field name="model">hrms.employee</field>
        <field name="arch" type="xml">
            <search string="Search Employees">
                <field name="name" string="Name"/>
                <field name="employee_code" string="Employee ID"/>
                <field name="department" string="Department"/>
                <field name="job_title" string="Job Title"/>
                <field name="email" string="Email"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Present Today" name="present" domain="[('status', '=', 'present')]"/>
                <filter string="On Leave" name="on_leave" domain="[('status', '=', 'on_leave')]"/>
                <filter string="Absent" name="absent" domain="[('status', '=', 'absent')]"/>
                <separator/>
                <filter string="Employees" name="role_employee" domain="[('role', '=', 'employee')]"/>
                <filter string="HR Officers" name="role_hr" domain="[('role', '=', 'hr')]"/>
                <group expand="0" string="Group By">
                    <filter string="Department" name="grp_dept" context="{'group_by': 'department'}"/>
                    <filter string="Role" name="grp_role" context="{'group_by': 'role'}"/>
                    <filter string="Status" name="grp_status" context="{'group_by': 'status'}"/>
                    <filter string="Employment Type" name="grp_type" context="{'group_by': 'employment_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────────── -->
    <record id="action_hrms_employee" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">hrms.employee</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_hrms_employee_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first employee
            </p>
            <p>Manage your workforce — profiles, attendance, leaves and payroll.</p>
        </field>
    </record>

</odoo>
