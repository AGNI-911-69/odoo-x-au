    <!-- ── Demo Attendance Records ───────────────────────────────────────── -->
    <record id="demo_att_sarah_today" model="hrms.attendance">
        <field name="employee_id" ref="demo_emp_sarah"/>
        <field name="date" eval="(DateTime.now()).strftime('%Y-%m-%d')"/>
        <field name="check_in" eval="(DateTime.now()).replace(hour=8, minute=42, second=0)"/>
        <field name="check_out" eval="(DateTime.now()).replace(hour=17, minute=15, second=0)"/>
