<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Employee ID Sequence -->
        <record id="seq_hrms_employee" model="ir.sequence">
            <field name="name">HRMS Employee Sequence</field>
            <field name="code">hrms.employee.sequence</field>
            <field name="prefix">EMP-</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1001</field>
        </record>

        <!-- Leave Types -->
        <record id="leave_type_annual" model="hrms.leave.type">
            <field name="name">Paid Annual Leave</field>
            <field name="code">ANNUAL</field>
            <field name="max_days">18</field>
            <field name="color">#5B2D8E</field>
        </record>

        <record id="leave_type_sick" model="hrms.leave.type">
            <field name="name">Sick Leave</field>
            <field name="code">SICK</field>
            <field name="max_days">7</field>
            <field name="color">#E74C3C</field>
        </record>

        <record id="leave_type_unpaid" model="hrms.leave.type">
            <field name="name">Unpaid Leave</field>
            <field name="code">UNPAID</field>
            <field name="max_days">3</field>
            <field name="color">#95A5A6</field>
        </record>

        <record id="leave_type_casual" model="hrms.leave.type">
            <field name="name">Casual Leave</field>
            <field name="code">CASUAL</field>
            <field name="max_days">5</field>
            <field name="color">#1ABC9C</field>
        </record>

    </data>
</odoo>
